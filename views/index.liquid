{% render 'partials/head.liquid' %}
{% comment %} <section>
    <button>Oost</button>
    <button>Zuid-oost</button>
    <button>Nieuw-West</button>
</section> {% endcomment %}

<main>
    <nav class="menu">
        <ul>
            <li>
                <a href="">Algemeen</a>
            </li>
            <li>
                <a href="">Archief</a>
            </li>
            <details>
                <summary><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg><span>Buurten</span></summary>
                <ul>
                    <li><a href="/Nieuw-west">Nieuw-West</a></li>
                    <li><a href="/Oost.liquid">Oost</a></li>
                    <li><a href="/Zuid-oost.liquid">Zuidoost</a></li>
                </ul>
            </details>
            <li>
                <a href="">Over</a>
            </li>
        </ul>
    </nav>

    <div class="input-section">
        <label for="sorteren">Sorteren</label>
        <select id="sorteren" onchange="location = this.value">
            <option value="/algemeen-nieuws-nieuw-oud">Nieuw → Oud</option>
            <option value="/algemeen-nieuws-oud-nieuw">Oud → Nieuw</option>
        </select>
    </div>

    {% for story in stories %}
    <article>
        <h2>{{ story.title }}</h2>    
        {% if story.cover.id  %}
            <img src="https://fdnd-agency.directus.app/assets/{{ story.cover.id }}" alt="" width="209" height="139">
            {% else %}
                <img src="/no-image-available-icon.jpg" width="209" height="139" alt="Afbeelding als er geen afbeelding beschikbaar is in Directus">
        {% endif %}
        {% if story.intro %}
                <p>{{ story.intro }}</p>
            {%  else %}
                <p>Geen text beschikbaar</p>
        {% endif %}
        <time>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M20 10V7C20 5.89543 19.1046 5 18 5H6C4.89543 5 4 5.89543 4 7V10M20 10V19C20 20.1046 19.1046 21 18 21H6C4.89543 21 4 20.1046 4 19V10M20 10H4M8 3V7M16 3V7" stroke="#000000" stroke-width="2" stroke-linecap="round"></path> <rect x="6" y="12" width="3" height="3" rx="0.5" fill="#000000"></rect> <rect x="10.5" y="12" width="3" height="3" rx="0.5" fill="#000000"></rect> <rect x="15" y="12" width="3" height="3" rx="0.5" fill="#000000"></rect> </g></svg>        
            {% if story.date %}
                <span>{{ story.date }}</span>
                {% else %}
                    <span>Niet aangegeven</span>
            {% endif %}            
        </time>
        <a href="">    
            <p>Lees meer →</p>
        </a>
    </article>
    {% endfor %}
</main>

{% render 'partials/foot.liquid' %}